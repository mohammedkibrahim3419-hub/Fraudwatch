{
  "manifest_version": 3,
  "name": "FraudWatch — Wallet Guard",
  "version": "1.0",
  "description": "Real-time scam protection. Warns you before sending funds to flagged wallets on Arc Testnet.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icon.png"
    }
  },
  "icons": {
    "32": "icon.png"
  }
}
